-- Function to extract words from TXT content (ULTRA FAST)
local function extractWordsFromTxtContent(txtContent)
    local words = {}
    local wordSet = {} -- For fast duplicate checking
    
    print("📄 ULTRA FAST processing, size:", #txtContent, "bytes")
    
    if dbStatus then
        dbStatus.Text = "Fast processing..."
        dbStatus.TextColor3 = Color3.fromRGB(255, 255, 0)
    end
    
    -- ULTRA FAST - no yields during processing
    local lineCount = 0
    local startTime = tick()
    
    -- Process in chunks to avoid timeout
    local lines = {}
    for line in txtContent:gmatch("[^\r\n]+") do
        table.insert(lines, line)
    end
    
    print("📄 Found", #lines, "total lines, processing...")
    
    -- Process all lines without yields
    for i, line in ipairs(lines) do
        lineCount = lineCount + 1
        local cleanWord = line:lower():gsub("%s+", ""):gsub("[^%w%-]", "")
        
        -- Filter valid Indonesian words (NO SYMBOLS)
        if cleanWord ~= "" and #cleanWord > 1 and #cleanWord < 25 then
            -- STRICT: Must contain only letters (no hyphens, numbers, symbols)
            if cleanWord:match("^[a-z]+$") then
                -- Fast duplicate check using hash table
                if not wordSet[cleanWord] then
                    wordSet[cleanWord] = true
                    table.insert(words, cleanWord)
                end
            end
        end
        
        -- Only yield every 50k lines (much less frequent)
        if lineCount % 50000 == 0 then
            print("📄 Processed", lineCount, "lines, found", #words, "words")
            wait(0.001) -- Minimal yield
        end
    end
    
    local totalTime = tick() - startTime
    print("📄 ULTRA FAST COMPLETE:", #words, "words from", lineCount, "lines in", math.floor(totalTime * 100) / 100, "seconds")
    return words
end

