-- Find word function - SIMPLE and RELIABLE
-- excludeSet: table berisi kata (uppercase) yang harus di-skip
local function findWord(prefix, excludeSet)
    prefix = string.upper(prefix)
    excludeSet = excludeSet or {}
    local shortWords = {}   -- 4-6 huruf (ideal, cepat diketik)
    local mediumWords = {}  -- 7-9 huruf
    local anyWords = {}     -- fallback
    
    print("🔍 SIMPLE SEARCH for prefix:", prefix)
    
    if not databaseLoaded or #allWords == 0 then
        print("  ❌ DATABASE NOT READY")
        return nil
    end
    
    -- Simple search - find all matching words
    for _, word in pairs(allWords) do
        local upperWord = string.upper(word)
        if string.sub(upperWord, 1, #prefix) == prefix and not excludeSet[upperWord] then
            local len = #word
            if len >= 4 and len <= 6 then
                table.insert(shortWords, word)
            elseif len >= 7 and len <= 9 then
                table.insert(mediumWords, word)
            elseif len >= 3 and len <= 12 then
                table.insert(anyWords, word)
            end
        end
    end
    
    -- Prioritas: pendek dulu supaya cepat diketik dan tidak overlap
    local pool = #shortWords > 0 and shortWords or (#mediumWords > 0 and mediumWords or anyWords)
    
    print("  Short(4-6):", #shortWords, "| Medium(7-9):", #mediumWords, "| Any:", #anyWords)
    
    if #pool > 0 then
        local selectedWord = pool[math.random(1, #pool)]
        print("  🎯 Selected:", selectedWord, "(len:", #selectedWord, ")")
        return selectedWord
    end
    
    print("  ❌ No matches found")
    return nil
end
local isTyping = false
local currentPrefix = ""

local function sendBackspace(count)
    for i = 1, count do
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Backspace, false, game)
            wait(0.03)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Backspace, false, game)
        end)
        wait(0.03)
    end
end

local function typeWord(word)
    for i = 1, #word do
        local char = string.upper(string.sub(word, i, i))
        local kc = Enum.KeyCode[char]
        if kc then
            pcall(function()
                VirtualInputManager:SendKeyEvent(true, kc, false, game)
                wait(0.05)
                VirtualInputManager:SendKeyEvent(false, kc, false, game)
            end)
            wait(0.08)
        end
    end
end

local function safeTyping(detectedPrefix, wordLabel)
    local rejectedWords = {}

    while true do
        -- Cari kata
        local word = findWord(detectedPrefix, rejectedWords)
        if not word then
            if statusLabel then statusLabel.Text = "Tidak ada kata untuk: " .. detectedPrefix end
            isTyping = false
            return
        end
        rejectedWords[word:upper()] = true

        -- Hapus + ketik
        sendBackspace(15)
        wait(0.1)
        local remaining = string.sub(word, #detectedPrefix + 1)
        if statusLabel then statusLabel.Text = "TYPING: " .. detectedPrefix .. " → " .. word end
        typeWord(remaining)
        wait(0.2)

        -- Enter
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
            wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        end)

        -- Tunggu 1 detik setelah enter
        wait(1)

        -- Cek awalan - kalau berubah berarti diterima, berhenti
        if wordLabel and wordLabel.Parent then
            local newText = wordLabel.Text
            if not newText or newText:upper() ~= detectedPrefix:upper() then
                successCount = successCount + 1
                if statsLabel then statsLabel.Text = "Success: " .. successCount .. " | Blocked: " .. blockedCount .. " | DB: " .. #allWords .. " kata" end
                if statusLabel then statusLabel.Text = "SUCCESS: " .. word end
                isTyping = false
                return
            end
        else
            isTyping = false
            return
        end

        -- Awalan masih sama = ditolak, ulangi dengan kata lain
        print("REJECTED:", word, "- coba lain")
    end
end

local function processSafeDetection(prefix, wordLabel)
    if not databaseLoaded then return end
    if isTyping then return end

    isTyping = true
    currentPrefix = prefix:upper()
    spawn(function()
        safeTyping(prefix, wordLabel)
    end)
end
-- Monitoring - scan semua descendants di PlayerGui, sama seperti file 1.lua
local function startFocusedMonitoring()
    if not databaseLoaded then
        statusLabel.Text = "Status: ERROR - Database not loaded | Click LOAD 79K first"
        return
    end
    
    if isActive then return end
    isActive = true
    
    startBtn.Text = "ACTIVE"
    startBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local myUsername = LocalPlayer.Name
    statusLabel.Text = "Status: SCANNING..."
    
    spawn(function()
        wait(1)
        
        print("MONITORING:", myUsername)
        myTextBoxes = {}

        local function attachToObject(obj)
            local objName = obj.Name:lower()
            local objPath = obj:GetFullName():lower()

            -- Harus di PlayerGui kita
            local yourPlayerGuiPath = "players." .. myUsername:lower() .. ".playergui"
            if not objPath:find(yourPlayerGuiPath, 1, true) then return end

            -- Harus nama mengandung "word"
            if not objName:find("word") then return end

            print("  ATTACH:", obj:GetFullName())
            table.insert(myTextBoxes, obj)

            local connection = obj:GetPropertyChangedSignal("Text"):Connect(function()
                local text = obj.Text
                if text and #text >= 1 and #text <= 3 and text:match("^[A-Za-z]+$") then
                    -- Tunggu sebentar pastikan awalan sudah final (handle 2 huruf seperti "AX")
                    wait(0.3)
                    local finalText = obj.Text
                    if finalText == text then
                        processSafeDetection(finalText, obj)
                    end
                end
            end)
            table.insert(monitorConnections, connection)
        end

        local function scanDescendants(parent)
            for _, obj in pairs(parent:GetDescendants()) do
                if obj:IsA("TextLabel") or obj:IsA("TextBox") then
                    attachToObject(obj)
                end
            end
        end

        -- Scan semua yang sudah ada di PlayerGui
        scanDescendants(playerGui)

        -- Tunggu MatchUI kalau belum ada
        local addConn = playerGui.ChildAdded:Connect(function(child)
            if child.Name == "MatchUI" and isActive then
                wait(0.5)
                scanDescendants(child)
                statusLabel.Text = "Status: ACTIVE - " .. #myTextBoxes .. " monitor"
            end
        end)
        table.insert(monitorConnections, addConn)

        statusLabel.Text = "Status: ACTIVE - " .. #myTextBoxes .. " monitor"
        print("Monitoring", #myTextBoxes, "elements untuk", myUsername)
    end)
end

-- Stop monitoring
local function stopFocusedMonitoring()
    isActive = false
    
    for _, connection in pairs(monitorConnections) do
        connection:Disconnect()
    end
    monitorConnections = {}
    myTextBoxes = {}
    currentFocusedTextBox = nil
    
    startBtn.Text = "START"
    startBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    statusLabel.Text = "Status: STOPPED"
    
    print("🛑 Strict monitoring stopped")
end

