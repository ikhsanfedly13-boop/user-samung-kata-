    print("🔘 LOAD button clicked!")
    
    pcall(function()
        print("  Database loaded:", databaseLoaded)
        print("  Current words count:", #allWords)
        
        if not databaseLoaded then
            print("  Starting download...")
            download79kDatabase()
        else
            print("  Database already loaded, forcing reload...")
            databaseLoaded = false
            allWords = {}
            download79kDatabase()
        end
    end)
end)

startBtn.MouseButton1Click:Connect(function()
    pcall(startFocusedMonitoring)
end)

stopBtn.MouseButton1Click:Connect(function()
    pcall(stopFocusedMonitoring)
end)

